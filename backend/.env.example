# HUNTER.OS - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── App ──────────────────────────────────────────────
DEBUG=true

# ── Database ─────────────────────────────────────────
# SQLite (dev): sqlite:///./hunter.db
# PostgreSQL (prod): postgresql://user:pass@host:5432/hunteros
DATABASE_URL=sqlite:///./hunter.db

# ── JWT Auth (REQUIRED) ─────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# ── Gemini / LLM (REQUIRED) ─────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Credential Encryption ───────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Email (Optional) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Bridge (Optional) ──────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LemonSqueezy (Optional) ─────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ── Google Search (Optional) ─────────────────────────
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
GOOGLE_NEWS_API_KEY=

# ── Default Sender ───────────────────────────────────
DEFAULT_FROM_EMAIL=

# ═════════════════════════════════════════════════════
# Phase 11 — Cost Optimization (2026 pricing)
# Every variable below is OPTIONAL. Empty = feature off,
# existing Phase 1-10 behaviour stays unchanged.
# ═════════════════════════════════════════════════════

# ── SERP Provider (cheapest 2026) ────────────────────
# ScrapingDog — $3 per 1,000 requests · Free: 1,000/mo
# Register: https://www.scrapingdog.com
SCRAPINGDOG_API_KEY=

# ── Enrichment (free tiers first) ────────────────────
# Apollo.io — free tier 50 people match/mo (email finder)
# Register: https://www.apollo.io
APOLLO_API_KEY=

# People Data Labs — free tier 1,000 records/mo
# NOTE: PDL does NOT find emails, only enriches profiles
# from an existing email. Runs AFTER Apollo in the waterfall.
# Register: https://www.peopledatalabs.com
PDL_API_KEY=

# ── Residential Proxy (cheapest 2026) ────────────────
# IPRoyal — ~$1.5/GB, sticky sessions supported
# Register: https://iproyal.com
IPROYAL_USERNAME=
IPROYAL_PASSWORD=
IPROYAL_ENDPOINT=geo.iproyal.com:12321
IPROYAL_POOL_SIZE=10

# ── Score thresholds (budget protection) ─────────────
# Leads below DISCOVERY threshold are NOT persisted.
# Leads below ENRICHMENT threshold are NOT enriched.
# Raise both to cut costs, lower to widen the funnel.
INTENT_SCORE_THRESHOLD_DISCOVERY=50
INTENT_SCORE_THRESHOLD_ENRICHMENT=60

# ── Cache TTL ────────────────────────────────────────
# How long SERP / footprint / enrichment results are cached.
CACHE_TTL_DAYS=30

# ═════════════════════════════════════════════════════
# HUNTER.OS PHASE 11 — Deploy / Production Variables
# ═════════════════════════════════════════════════════

# ── CELERY (Background Tasks) ────────────────────────
# ADDED (Phase 11): Celery worker + beat share this broker.
# Railway auto-injects REDIS_URL; point Celery at it too.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── DOCKER / PRODUCTION ──────────────────────────────
DOCKER_ENVIRONMENT=production
# NOTE: `DEBUG` above must be flipped to False in prod.
# SECRET_KEY and ENCRYPTION_KEY must be generated for prod
# (see generation commands in the top "JWT Auth" + "Credential
# Encryption" blocks). Never reuse dev keys in production.

# ── FRONTEND CORS ────────────────────────────────────
# Comma-separated list of allowed origins for the browser client.
CORS_ORIGINS=https://hunteros.app,https://www.hunteros.app

# ── SMTP / EMAIL (Optional — outreach feature) ───────
# NOTE: SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASSWORD
# are already declared above. These two are deploy-only extras.
SMTP_FROM_EMAIL=noreply@hunteros.app
SMTP_FROM_NAME=HUNTER.OS

# ── MONITORING (Optional) ────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
